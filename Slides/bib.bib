@article{Kocherlakota,
 ISSN = {00346527, 1467937X},
 URL = {http://www.jstor.org/stable/2297795},
 abstract = {Consumption data generally indicates that consumption risk is not perfectly diversified across individuals. This paper considers if and when imperfect diversification is a feature of efficient allocations in a symmetric information environment without commitment. It shows that if individuals are sufficiently patient, imperfect diversification is always sub-optimal in the long run; however, if individuals are not so patient, imperfect diversification is always optimal. The paper goes on to demonstrate that the way that history matters in an efficient allocation in a symmetric-information/no-commitment environment can be used to distinguish lack of commitment from other possible rationalizations of imperfect risk sharing, such as efficiency in the presence of asymmetric information.},
 author = {Narayana R. Kocherlakota},
 journal = {The Review of Economic Studies},
 number = {4},
 pages = {595--609},
 publisher = {[Oxford University Press, Review of Economic Studies, Ltd.]},
 title = {Implications of Efficient Risk Sharing without Commitment},
 urldate = {2024-03-16},
 volume = {63},
 year = {1996}
}



